#include <stdio.h>

int main() {
    int size;
    int sum = 0;

    printf("Enter the size of the array\n");
    scanf("%d", &size);

    int arr[size];

    printf("Enter %d elements\n", size);

    for (int i = 0; i < size; i++) {
        scanf("%d", &arr[i]);
        sum = sum + arr[i];
    }

    printf("Sum is : %d\n", sum);
    printf("Average is : %d\n", sum / size);

    return 0;
}
