#include <stdio.h>

int main() {
    int size;

    printf("Enter the size of the array\n");
    scanf("%d", &size);

    int arr[size];

    printf("Enter %d elements\n", size);

    for (int i = 0; i < size; i++) {
        scanf("%d", &arr[i]);
    }

    int largest = arr[0];

    for (int i = 0; i < size - 1; i++) {
        if (largest < arr[i]) {
            largest = arr[i];
        }
    }

    printf("Largest element is : %d\n", largest);

    return 0;
}
