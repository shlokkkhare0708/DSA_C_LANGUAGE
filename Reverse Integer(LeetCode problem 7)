#include <stdio.h>
#include <limits.h>

int reverse(int x) {
    int min = INT_MIN;
    int max = INT_MAX;

    if (x == min || x == max) {
        return 0;
    }

    int rev = 0;

    while (x != 0) {
        int lastDigit = x % 10;

        if (rev > max / 10 || rev < min / 10) {
            return 0;
        }

        rev = rev * 10 + lastDigit;
        x = x / 10;
    }

    return rev;
}

int main() {
    int x;

    printf("Enter a number: ");
    scanf("%d", &x);

    printf("Reversed Number: %d\n", reverse(x));

    return 0;
}
